# ---- Database ----
# Local/dev:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tlc?schema=public"
# Replit Autoscale (production): instances are stateless and scale horizontally,
# so DATABASE_URL must be a POOLED connection or you will exhaust Postgres
# connections. Example (Neon pooled / PgBouncer):
#   DATABASE_URL="postgresql://user:pass@HOST/db?sslmode=require&pgbouncer=true&connection_limit=1"

# ---- Auth.js (NextAuth v5) ----
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-me"
AUTH_URL="http://localhost:3000"

# Optional corporate SSO (OIDC) — Phase 8, additive
AUTH_OKTA_ID=""
AUTH_OKTA_SECRET=""
AUTH_OKTA_ISSUER=""

# ---- Stripe (backend only) ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ---- ThriveCart (optional hosted cart) ----
THRIVECART_WEBHOOK_SECRET=""

# ---- SendGrid ----
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="tri.nguyen@thewisdomtri.com"
SENDGRID_FROM_NAME="The Wisdom Tri"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
